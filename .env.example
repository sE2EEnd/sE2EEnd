# sE2EEnd Environment Configuration
# Copy this file to .env and adjust values as needed

# ======================
# DATABASE CONFIGURATION
# ======================
POSTGRES_USER=se2eend
POSTGRES_PASSWORD=se2eend

# ======================
# KEYCLOAK CONFIGURATION
# ======================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=se2eend
# External URL (as seen by the browser, used for JWT issuer validation)
KEYCLOAK_EXTERNAL_URL=http://localhost:8090

# Keycloak Theme Colors (optional customization)
THEME_COLOR_PRIMARY=#2563eb
THEME_COLOR_PRIMARY_DARK=#1d4ed8
THEME_COLOR_PRIMARY_LIGHT=#3b82f6

# ======================
# APPLICATION
# ======================
FRONTEND_URL=http://localhost

# ======================
# STORAGE CONFIGURATION
# ======================
# Provider: "local" (default) or "s3"
STORAGE_PROVIDER=local

# Local storage — used when STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_DIR=./uploads

# S3 storage — used when STORAGE_PROVIDER=s3
# Compatible with AWS S3 and S3-compatible providers (MinIO, Scaleway, OVHcloud, etc.)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
# Optional: custom endpoint URL for S3-compatible storage (e.g. https://s3.example.com)
# Leave empty for standard AWS S3
STORAGE_S3_ENDPOINT=
# Set to true for MinIO and other providers that require path-style access
STORAGE_S3_PATH_STYLE=false